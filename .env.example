# ============================================
# SecureQA Orchestrator — Environment Variables
# ============================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to version control.

# --- API Keys ---

# Google Gemini API key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ClickUp API key (optional — needed only for ClickUp ticket creation)
# Get one at https://app.clickup.com/settings/apps
CLICKUP_API_KEY=

# --- LLM Configuration ---

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash-lite

# Temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.2

# Max tokens per response
LLM_MAX_TOKENS=4096

# Timeout per LLM call in seconds
LLM_TIMEOUT_SECONDS=30

# --- Storage ---

# SQLite database file path (relative to project root)
DB_PATH=data/scans.db

# Log file directory
LOG_DIR=data/logs

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Safety ---

# Path to target allowlist JSON
ALLOWLIST_PATH=config/target_allowlist.json

# Block production URLs (true = safe default)
BLOCK_PRODUCTION=true

# --- App ---

APP_NAME=SecureQA Orchestrator

# Environment: development | staging | production
ENVIRONMENT=development
